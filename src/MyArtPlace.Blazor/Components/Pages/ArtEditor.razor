@page "/add"
@page "/edit/{Id:int}"
@rendermode InteractiveServer
@inject ArtEditorViewModel VM
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>@(VM.IsEditing ? "Edit Art" : "Add Art") - MyArtPlace</PageTitle>

<div class="toolbar">
    <h1>@(VM.IsEditing ? "Edit Art Piece" : "Add New Art Piece")</h1>
    <a href="/" class="btn btn-secondary" style="margin-left: auto;">Back to Gallery</a>
</div>

@if (VM.ErrorMessage is not null)
{
    <div class="alert alert-error">@VM.ErrorMessage</div>
}
@if (VM.SuccessMessage is not null)
{
    <div class="alert alert-success">@VM.SuccessMessage</div>
}

<div style="background: #fff; padding: 1.5rem; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); max-width: 600px;">
    <div class="form-group">
        <label>Title *</label>
        <input type="text" @bind="VM.Title" />
    </div>
    <div class="form-group">
        <label>Artist *</label>
        <input type="text" @bind="VM.Artist" />
    </div>
    <div class="form-group">
        <label>Category</label>
        <select @bind="VM.Category">
            @foreach (var cat in VM.Categories)
            {
                <option value="@cat">@cat</option>
            }
        </select>
    </div>
    <div class="form-group">
        <label>Year Created</label>
        <input type="number" @bind="VM.YearCreated" />
    </div>
    <div class="form-group">
        <label>Description</label>
        <textarea @bind="VM.Description"></textarea>
    </div>
    <div class="form-group">
        <label>Image URL</label>
        <input type="text" @bind="VM.ImageUrl" placeholder="https://example.com/image.jpg" />
    </div>
    <div class="form-group">
        <label>Image (drag &amp; drop or click to upload)</label>
        <div class="drop-zone @(_isDragOver ? "drop-zone-active" : "")"
             ondragover="event.preventDefault();"
             @ondragenter="OnDragEnter"
             @ondragleave="OnDragLeave"
             @ondrop="OnDragLeave">
            @if (VM.ImagePreviewUrl is not null)
            {
                <div class="drop-zone-preview">
                    <img src="@VM.ImagePreviewUrl" alt="Preview" />
                    <button type="button" class="btn btn-danger btn-sm" @onclick="RemoveImage">Remove</button>
                </div>
            }
            else
            {
                <div class="drop-zone-prompt">
                    <span style="font-size: 2rem;">📁</span>
                    <p>Drag &amp; drop an image here, or click to browse</p>
                </div>
            }
            <InputFile OnChange="OnFileSelected" accept="image/*"
                       style="position: absolute; inset: 0; opacity: 0; cursor: pointer;" />
        </div>
    </div>
    <div class="form-group">
        <label>Price ($)</label>
        <input type="number" step="0.01" @bind="VM.Price" />
    </div>
    <div style="display: flex; gap: 0.5rem;">
        <button class="btn btn-success" @onclick="VM.SaveCommand.ExecuteAsync">
            @(VM.IsEditing ? "Update" : "Save")
        </button>
        @if (VM.IsEditing)
        {
            <button class="btn btn-danger" @onclick="DeleteArt">Delete</button>
        }
        <a href="/" class="btn btn-secondary">Cancel</a>
    </div>
</div>

@code {
    [Parameter] public int? Id { get; set; }
    [Inject] private IRepository<ArtPiece> ArtRepo { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private bool _isDragOver;
    private const long MaxFileSize = 5 * 1024 * 1024; // 5 MB

    private void OnDragEnter() => _isDragOver = true;
    private void OnDragLeave() => _isDragOver = false;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _isDragOver = false;
        var file = e.File;
        if (file is null) return;

        if (!file.ContentType.StartsWith("image/"))
        {
            VM.ErrorMessage = "Only image files are allowed.";
            return;
        }
        if (file.Size > MaxFileSize)
        {
            VM.ErrorMessage = "Image must be smaller than 5 MB.";
            return;
        }

        using var ms = new MemoryStream();
        await file.OpenReadStream(MaxFileSize).CopyToAsync(ms);
        VM.SetImage(ms.ToArray(), file.ContentType);
    }

    private void RemoveImage() => VM.ClearImage();

    private async Task DeleteArt()
    {
        await ArtRepo.DeleteAsync(VM.Id);
        Nav.NavigateTo("/");
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Id.HasValue)
        {
            var art = await ArtRepo.GetByIdAsync(Id.Value);
            if (art is not null)
                VM.LoadForEdit(art);
        }
        else
        {
            VM.LoadForCreate();
        }
    }
}
