<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MyArtPlace.Avalonia.Views.ArtEditorView">
    <ScrollViewer>
        <StackPanel Margin="10" Spacing="10" MaxWidth="500">
            <TextBlock Text="Add / Edit Art Piece" FontSize="20" FontWeight="Bold"/>
            
            <TextBlock x:Name="TxtMessage" IsVisible="False" Padding="8" FontSize="12"/>

            <TextBlock Text="Title *" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtTitle" Watermark="Enter title..."/>

            <TextBlock Text="Artist *" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtArtist" Watermark="Enter artist name..."/>

            <TextBlock Text="Category" FontWeight="SemiBold"/>
            <ComboBox x:Name="CmbCategory" MinWidth="200"/>

            <TextBlock Text="Year Created" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtYear" Watermark="e.g. 2024"/>

            <TextBlock Text="Description" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtDescription" AcceptsReturn="True" MinHeight="60" Watermark="Enter description..."/>

            <TextBlock Text="Image URL" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtImageUrl" Watermark="https://example.com/image.jpg"/>

            <TextBlock Text="Image (drag &amp; drop a file here)" FontWeight="SemiBold"/>
            <Border x:Name="DropZone" Background="#F5F5F5" BorderBrush="#CCCCCC" BorderThickness="2"
                    CornerRadius="8" MinHeight="120" Padding="10"
                    DragDrop.AllowDrop="True">
                <Panel>
                    <StackPanel x:Name="DropPrompt" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="5">
                        <TextBlock Text="📁" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="Drag &amp; drop an image file here" Foreground="Gray" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel x:Name="ImagePreviewPanel" IsVisible="False" HorizontalAlignment="Center" Spacing="5">
                        <Image x:Name="ImgPreview" MaxHeight="180" MaxWidth="400" Stretch="Uniform"/>
                        <Button x:Name="BtnRemoveImage" Content="Remove Image" Background="#c62828" Foreground="White"
                                Padding="10,4" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Panel>
            </Border>

            <TextBlock Text="Price ($)" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtPrice" Watermark="e.g. 1000"/>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="BtnSave" Content="Save" Background="#2e7d32" Foreground="White" Padding="15,8"/>
                <Button x:Name="BtnClear" Content="New" Background="#757575" Foreground="White" Padding="15,8"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
