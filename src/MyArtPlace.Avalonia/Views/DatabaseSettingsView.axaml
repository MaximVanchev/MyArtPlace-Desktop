<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MyArtPlace.Avalonia.Views.DatabaseSettingsView">
    <StackPanel Margin="20" Spacing="15" MaxWidth="400">
        <TextBlock Text="Database Settings" FontSize="20" FontWeight="Bold"/>
        <TextBlock Text="Switch between PostgreSQL and MySQL (Requirement 3)" Foreground="Gray"/>

        <TextBlock Text="Current Provider:" FontWeight="SemiBold"/>
        <TextBlock x:Name="TxtCurrentDb" FontSize="16" Foreground="#1565c0"/>

        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button x:Name="BtnPostgres" Content="PostgreSQL" Padding="15,8"/>
            <Button x:Name="BtnMySql" Content="MySQL" Padding="15,8"/>
        </StackPanel>

        <TextBlock x:Name="TxtStatus" Foreground="Green"/>

        <TextBlock Text="Both databases contain the same seeded data. Switching will cause subsequent queries to use the selected database." 
                   Foreground="Gray" FontSize="12" TextWrapping="Wrap"/>
    </StackPanel>
</UserControl>
